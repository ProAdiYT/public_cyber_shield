# =================================================================
# CITIZEN CYBER SHIELD - LOCAL ENVIRONMENT CONFIGURATION TEMPLATE
# =================================================================
# Rename this file to .env and configure the variables for local run.

# Host and Port Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=8080
STREAMLIT_PORT=8501

# Debug Mode
DEBUG=True

# Thread Management (Avoid memory allocation bottlenecks on constrained host devices)
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
